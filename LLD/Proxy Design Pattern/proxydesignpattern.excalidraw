    {
      "id": "EauWMTwXpmI6Or5P8Kg44",
      "type": "text",
      "x": 0,
      "y": 1671.4000091552734,
      "width": 967.0598754882812,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ak",
      "roundness": null,
      "seed": 1056566306,
      "version": 298,
      "versionNonce": 2069192226,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777097216407,
      "link": null,
      "locked": false,
      "text": "Protection Proxy :- Same like we have an UnlockPdbf Document Reader then to make sure\nwe dont access the actual function in we use the protection proxy to validate the users \nthat have the unlock feature ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Protection Proxy :- Same like we have an UnlockPdbf Document Reader then to make sure\nwe dont access the actual function in we use the protection proxy to validate the users \nthat have the unlock feature ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "2X0dwbJM_w16GIPwhuN3_",
      "type": "text",
      "x": 32,
      "y": 1794,
      "width": 840.9794311523438,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "am",
      "roundness": null,
      "seed": 630282366,
      "version": 314,
      "versionNonce": 123340478,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777097525449,
      "link": null,
      "locked": false,
      "text": "in protection we first check if the proxy has the usr ka instance hence it will check ki\nif the user has an access to unlock the document or not, this is like protection proxy\nwe added validation layer throgh a proxy to client to protect the actual functionaliy",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
