    },
    {
      "id": "lgPHLaWbdclfNNCBeWaH0",
      "type": "text",
      "x": 355,
      "y": 678,
      "width": 618.5796508789062,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
