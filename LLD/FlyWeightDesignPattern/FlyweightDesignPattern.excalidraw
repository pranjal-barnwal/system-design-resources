      "isDeleted": false,
      "boundElements": [],
      "updated": 1777113563919,
      "link": null,
      "locked": false,
      "text": "To make the object light weight like in astroid class size is 1MB and\nwe need to create millions of astroid them memory will not be sufficient",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To make the object light weight like in astroid class size is 1MB and\nwe need to create millions of astroid them memory will not be sufficient",
      "autoResize": true,
