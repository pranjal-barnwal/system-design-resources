      "updated": 1777113603837,
      "link": null,
      "locked": false,
      "text": "So to make the object light weight break it in to the 2 things 1. Instrinsic Properties 2. Extrinsic Properties",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So to make the object light weight break it in to the 2 things 1. Instrinsic Properties 2. Extrinsic Properties",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Y2UpQ6DoE_KlmMTkOCZt_",
      "type": "text",
      "x": 379.20001220703125,
      "y": 718.3999938964844,
      "width": 1210.979248046875,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
