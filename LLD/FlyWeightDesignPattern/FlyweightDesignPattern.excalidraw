    {
      "id": "1lzDhqVCxnhBPy6nlauM6",
      "type": "text",
      "x": 528.0000305175781,
      "y": 1660.3777618408205,
      "width": 1079.1192626953125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
