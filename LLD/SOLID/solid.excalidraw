    {
      "id": "hPAWhITUg5Jf4jv_4Hn_k",
      "type": "text",
      "x": 222.80951879857628,
      "y": 2192.5135955211886,
      "width": 1193.219482421875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
