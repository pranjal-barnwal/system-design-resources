      "isDeleted": false,
      "boundElements": [],
      "updated": 1774629526951,
      "link": null,
      "locked": false,
      "text": "    Subclass should be substitude for their base class!  ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    Subclass should be substitude for their base class!  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LFTL8DJohOsrdFO06aXyJ",
      "type": "text",
      "x": -284.1452249276243,
      "y": 5160.430951920487,
      "width": 775.4994506835938,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
