      "seed": 1108127512,
      "version": 87,
      "versionNonce": 884354928,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774788653116,
      "link": null,
      "locked": false,
      "text": "Subclass should always expand the features of base class not narrow down it!!",
      "fontSize": 20,
      "fontFamily": 5,
