      "boundElements": [],
      "updated": 1774613552268,
      "link": null,
      "locked": false,
      "text": "In a Class we have multiple\nfor loops and switch case\nlike in the future we might need \nto add more funcationaliyy like\npayWithUpi or payWithAmex\nthen we need to update the switch case\nor for loop then this violates OCP",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In a Class we have multiple\nfor loops and switch case\nlike in the future we might need \nto add more funcationaliyy like\npayWithUpi or payWithAmex\nthen we need to update the switch case\nor for loop then this violates OCP",
      "autoResize": true,
      "lineHeight": 1.25
    },
