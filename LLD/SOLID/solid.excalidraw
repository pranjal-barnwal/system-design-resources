      "boundElements": [],
      "updated": 1773678973909,
      "link": null,
      "locked": false,
      "text": "A BODY CAN EXISIT WITHOUT EYE\nBUT AN EYE CANNOT EXISIST WITHOUT BODY\nTHIS IS COMPOSITION\nIF BODDY IS DESTROYED AN EYE IS ALSO\nDESTROYED!!!",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A BODY CAN EXISIT WITHOUT EYE\nBUT AN EYE CANNOT EXISIST WITHOUT BODY\nTHIS IS COMPOSITION\nIF BODDY IS DESTROYED AN EYE IS ALSO DESTROYED!!!",
      "autoResize": false,
      "lineHeight": 1.25
    },
