      "versionNonce": 1689850648,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774612306441,
      "link": null,
      "locked": false,
      "text": "A Class, entity, Module or function should have only one reason to change ( it should only have one responsibility )\nA Class should have only one reason to change!!!, in one class there can be multiple methods but thes methods should be doing the similar kind of thing! \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Class, entity, Module or function should have only one reason to change ( it should only have one responsibility )\nA Class should have only one reason to change!!!, in one class there can be multiple methods but thes methods should be doing the similar kind of thing! \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
