      "seed": 730530328,
      "version": 48,
      "versionNonce": 230413592,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774612366167,
      "link": null,
      "locked": false,
      "text": "2. OCP :- Open Close Principle\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. OCP :- Open Close Principle\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gLEDMhHyII7BhKW2jJLhV",
      "type": "text",
      "x": 181.13171055444553,
      "y": 2397.6170670275474,
      "width": 1283.8590087890625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3c",
      "roundness": null,
      "seed": 484297752,
      "version": 424,
      "versionNonce": 1929707368,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774613835915,
      "link": null,
      "locked": false,
      "text": "A Class or Module or Entiry should be Open for Extension and Closed for Modification, means future me functionality add karni ho \nthen exisiting code ko change na karna pade simple class ko extend kar sake, \nMeans avoid for loops or switch cases, \nTo add a functionality minimum amount code changes should be do in exisiting class!!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Class or Module or Entiry should be Open for Extension and Closed for Modification, means future me functionality add karni ho \nthen exisiting code ko change na karna pade simple class ko extend kar sake, \nMeans avoid for loops or switch cases, \nTo add a functionality minimum amount code changes should be do in exisiting class!!",
      "autoResize": true,
      "lineHeight": 1.25
    },
