      "index": "b3U",
      "roundness": null,
      "seed": 981995032,
      "version": 271,
      "versionNonce": 188351512,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774611666610,
      "link": null,
      "locked": false,
      "text": "TO Fix the SRP :- first break the classes into multiple classes, then use the composition like has a, has a, etc, and then \nwherever we can simple follow the DIP and turn the compotition into the abstraction using interfaces.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TO Fix the SRP :- first break the classes into multiple classes, then use the composition like has a, has a, etc, and then \nwherever we can simple follow the DIP and turn the compotition into the abstraction using interfaces.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IywliBRG2fw5HHaMlQkfH",
      "type": "text",
      "x": 177.85644799617938,
      "y": 2313.494676135707,
      "width": 407.98785400390625,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
