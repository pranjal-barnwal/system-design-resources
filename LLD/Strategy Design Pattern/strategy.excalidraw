      "isDeleted": false,
      "boundElements": [],
      "updated": 1774868430354,
      "link": null,
      "locked": false,
      "text": "Family of Algorithms like ( Payment Stretegies, Robot Creation Strategies etc.)\nand put then into saparate classes so that they can be changed at runtime",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Family of Algorithms like ( Payment Stretegies, Robot Creation Strategies etc.)\nand put then into saparate classes so that they can be changed at runtime",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YgqEgSZGhF9jLKvRqkSna",
      "type": "text",
      "x": 835.8203641156011,
      "y": 959.726536365315,
      "width": 1105.119384765625,
      "height": 75,
      "angle": 0,
