    },
    {
      "id": "QbEokkv6Bc7bbQmA42bqe",
      "type": "text",
      "x": 106.02478144561348,
      "y": 6317.78646125852,
      "width": 929.1994018554688,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 472397189,
      "version": 335,
      "versionNonce": 1398499877,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781447341166,
      "link": null,
      "locked": false,
      "text": "In previous approaches during Method Chaining, we were getting reference of Builder everytime.\nBut here we create Abstract-class/Interface for every Attribute and will have its function, \nwhich will return reference Interface Object for next step.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In previous approaches during Method Chaining, we were getting reference of Builder everytime.\nBut here we create Abstract-class/Interface for every Attribute and will have its function, \nwhich will return reference Interface Object for next step.",
      "autoResize": true,
      "lineHeight": 1.25
    },
