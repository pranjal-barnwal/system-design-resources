    {
      "id": "s_FDv6JmoJnMIMT1SG94E",
      "type": "text",
      "x": 203.87877541784036,
      "y": 1871.8246599058275,
      "width": 545.0058158563098,
      "height": 90.26865433673453,
      "angle": 0,
