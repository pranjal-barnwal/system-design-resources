    {
      "id": "fUo8u8-5UTFOCM1KMRhYa",
      "type": "text",
      "x": 897.53101987472,
      "y": 3797.5796123952864,
      "width": 787.4594116210938,
      "height": 175,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 261784115,
      "version": 268,
      "versionNonce": 1272767717,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781444125757,
      "link": null,
      "locked": false,
      "text": "Instead of Client directly requesting Target's object, it rather requests Builder \nto obtain and avoid problems we previously discussed.\n\nTypes of Builder:\n    1. Normal Builder\n    2. Director Builder\n    3. Steps Builder",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Instead of Client directly requesting Target's object, it rather requests Builder \nto obtain and avoid problems we previously discussed.\n\nTypes of Builder:\n    1. Normal Builder\n    2. Director Builder\n    3. Steps Builder",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YcTdWyM6yBsNurL_3rrt0",
      "type": "text",
      "x": 184.5389132122383,
      "y": 4094.531322346332,
      "width": 285.87591552734375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "aQ",
      "roundness": null,
      "seed": 1240412861,
      "version": 317,
      "versionNonce": 2105042109,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781434445560,
      "link": null,
      "locked": false,
      "text": "1. Normal Builder",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Normal Builder",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "2ZdOe-Pk-XtyDsXHC47H_",
      "type": "text",
      "x": 190.79715122346556,
      "y": 4163.521270354453,
      "width": 1063.0792236328125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "aR",
      "roundness": null,
      "seed": 1207699667,
      "version": 632,
      "versionNonce": 131214251,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781440536014,
      "link": null,
      "locked": false,
      "text": "To avoid creation of new Target objects directly by Client, we make Constructor of Target to be PRIVATE.\n\n- allows Method-Chaining since Builder always returns reference of itself, which can edit Target reference\n- and to finally get the Target Object, we call build() function to obtain actual reference\n- we nest the builder class inside Target class, so Builder can access constructor of Target \n    and make it static, so can be accessed w/o creating Object of it\n- naming convention is to start Chaining events with `with` ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To avoid creation of new Target objects directly by Client, we make Constructor of Target to be PRIVATE.\n\n- allows Method-Chaining since Builder always returns reference of itself, which can edit Target reference\n- and to finally get the Target Object, we call build() function to obtain actual reference\n- we nest the builder class inside Target class, so Builder can access constructor of Target \n    and make it static, so can be accessed w/o creating Object of it\n- naming convention is to start Chaining events with `with` ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ixoytldAv6BYE2lT4tfze",
      "type": "text",
      "x": 854.1824306993446,
      "y": 4581.283429542091,
      "width": 803,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 605436389,
      "version": 190,
      "versionNonce": 872876229,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781437793126,
      "link": null,
      "locked": false,
      "text": "HttpRequest stepRequest = HttpRequest.HttpRequestStepBuilder.getBuilder()\n    .withUrl(\"https://api.example.com/products\")\n    .withMethod(\"POST\")\n    .withHeader(\"Content-Type\", \"application/json\")\n    .withBody(\"{\\\"product\\\": \\\"Laptop\\\", \\\"price\\\": 49999}\")\n    .withTimeout(45)\n    .build();\n\nstepRequest.execute();",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HttpRequest stepRequest = HttpRequest.HttpRequestStepBuilder.getBuilder()\n    .withUrl(\"https://api.example.com/products\")\n    .withMethod(\"POST\")\n    .withHeader(\"Content-Type\", \"application/json\")\n    .withBody(\"{\\\"product\\\": \\\"Laptop\\\", \\\"price\\\": 49999}\")\n    .withTimeout(45)\n    .build();\n\nstepRequest.execute();",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uiRLiWE4pOtb30H-tEHU_",
      "type": "text",
      "x": 100.17706689337467,
      "y": 4385.516172079401,
      "width": 792,
      "height": 725,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 280032325,
      "version": 216,
      "versionNonce": 2007554277,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781442084822,
      "link": null,
      "locked": false,
      "text": "public class HttpRequest {\n    ...\n\n    static class HttpRequestStepBuilder implements UrlStep, MethodStep {\n        private HttpRequest req;\n\n        private HttpRequestStepBuilder() {\n            req = new HttpRequest();\n        }\n\n        // UrlStep implementation\n        public MethodStep withUrl(String url) {\n            req.url = url;\n            return this;\n        }\n\n        public HttpRequest build() {\n            if (req.url == null || req.url.isEmpty()) {\n                throw new RuntimeException(\"URL cannot be empty\");\n            }\n            return req;\n        }\n\n        // Static method to start the building process\n        public static UrlStep getBuilder() {\n            return new HttpRequestStepBuilder();\n        }\n    }\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class HttpRequest {\n    ...\n\n    static class HttpRequestStepBuilder implements UrlStep, MethodStep {\n        private HttpRequest req;\n\n        private HttpRequestStepBuilder() {\n            req = new HttpRequest();\n        }\n\n        // UrlStep implementation\n        public MethodStep withUrl(String url) {\n            req.url = url;\n            return this;\n        }\n\n        public HttpRequest build() {\n            if (req.url == null || req.url.isEmpty()) {\n                throw new RuntimeException(\"URL cannot be empty\");\n            }\n            return req;\n        }\n\n        // Static method to start the building process\n        public static UrlStep getBuilder() {\n            return new HttpRequestStepBuilder();\n        }\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9FupHedQR6YhqXLDmGq29",
      "type": "text",
      "x": 88.61737405507583,
      "y": 5216.70670379582,
      "width": 328.6078796386719,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "at",
      "roundness": null,
      "seed": 1932734821,
      "version": 386,
      "versionNonce": 1051224203,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781441708180,
      "link": null,
      "locked": false,
      "text": "2. Director Builder",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Director Builder",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "28f8ofrCKBS5lL_F3AAuH",
      "type": "text",
      "x": 117.62882634562493,
      "y": 5284.9623008107465,
      "width": 1159.2593994140625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 405279845,
      "version": 884,
      "versionNonce": 238215659,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781442057316,
      "link": null,
      "locked": false,
      "text": "Creates pre-existing templates of above Builder, so we don't have to start from scratch everytime and do all chaining.\nIt can be considered as an extension of Simple Builder.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Creates pre-existing templates of above Builder, so we don't have to start from scratch everytime and do all chaining.\nIt can be considered as an extension of Simple Builder.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mnIuisUkUOcYTr5JpkY0k",
      "type": "text",
      "x": 158.72417510232972,
      "y": 5339.579838124179,
      "width": 902,
      "height": 475,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 608663947,
      "version": 80,
      "versionNonce": 1492596523,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781442064038,
      "link": null,
      "locked": false,
      "text": "public class HttpRequestDirector {\n    public static HttpRequest createGetRequest(String url) {\n        return new HttpRequest.HttpRequestBuilder()\n                .withUrl(url)\n                .withMethod(\"GET\")\n                .build();\n    }\n\n    // Creates a JSON POST request\n    public static HttpRequest createJsonPostRequest(String url, String jsonBody) {\n        return new HttpRequest.HttpRequestBuilder()\n            .withUrl(url)\n            .withMethod(\"POST\")\n            .withHeader(\"Content-Type\", \"application/json\")\n            .withHeader(\"Accept\", \"application/json\")\n            .withBody(jsonBody)\n            .build();\n    }\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class HttpRequestDirector {\n    public static HttpRequest createGetRequest(String url) {\n        return new HttpRequest.HttpRequestBuilder()\n                .withUrl(url)\n                .withMethod(\"GET\")\n                .build();\n    }\n\n    // Creates a JSON POST request\n    public static HttpRequest createJsonPostRequest(String url, String jsonBody) {\n        return new HttpRequest.HttpRequestBuilder()\n            .withUrl(url)\n            .withMethod(\"POST\")\n            .withHeader(\"Content-Type\", \"application/json\")\n            .withHeader(\"Accept\", \"application/json\")\n            .withBody(jsonBody)\n            .build();\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "2p2gCkESNQZjz7RChEdAn",
      "type": "text",
      "x": 87.44728752179972,
      "y": 5916.712534019705,
      "width": 261.46795654296875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
