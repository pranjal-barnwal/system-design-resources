      "isDeleted": false,
      "boundElements": [],
      "updated": 1781441840738,
      "link": null,
      "locked": false,
      "text": "3. Step Builder",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Step Builder",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5VZfbTCae4tllZS-3ULA_",
      "type": "text",
      "x": 156.0889139083,
      "y": 5978.041825064479,
      "width": 936.5191650390625,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0G",
      "roundness": null,
      "seed": 84549445,
      "version": 414,
      "versionNonce": 431058437,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781444058531,
      "link": null,
      "locked": false,
      "text": "Helps in situations where Objects are supposed to be build Step-by-Step, in some order. \n\nLike think of Pizza, we first decide base-crust, then sauces, toppings, cheese and finally spices.\nWe can't add Cheese before preparing Crust\n\nIt helps in:\n1. creating Object step-by-step\n2. checking all parameters are declared or not (optional feature)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Helps in situations where Objects are supposed to be build Step-by-Step, in some order. \n\nLike think of Pizza, we first decide base-crust, then sauces, toppings, cheese and finally spices.\nWe can't add Cheese before preparing Crust\n\nIt helps in:\n1. creating Object step-by-step\n2. checking all parameters are declared or not (optional feature)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uC2-bVC7td_VUzZrPD-B8",
      "type": "text",
      "x": 106.01312099785227,
      "y": 6224.689446333136,
      "width": 1062.9591064453125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0H",
      "roundness": null,
      "seed": 76451333,
      "version": 275,
      "versionNonce": 2043724299,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781448320974,
      "link": null,
      "locked": false,
      "text": "It's always recommended to avoid Interitance altogether and instead use Composition.\nBut here, we actually require Multiple-Inheritance; even if not directly supported in Java through Interfaces.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's always recommended to avoid Interitance altogether and instead use Composition.\nBut here, we actually require Multiple-Inheritance; even if not directly supported in Java through Interfaces.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oKi_rAe7Wq-sxANFttmrc",
      "type": "text",
      "x": 202.86856549320981,
      "y": 3739.456237377919,
      "width": 141.04794311523438,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 1369073221,
      "version": 636,
      "versionNonce": 2116736171,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781444129755,
      "link": null,
      "locked": false,
      "text": "Solution",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solution",
      "autoResize": true,
