    {
      "id": "HBP680t0ppYj67jL8CVm_",
      "type": "text",
      "x": 396.7259216308594,
      "y": 2708.2999877929688,
      "width": 1458.619140625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
