      "index": "b0u",
      "roundness": null,
      "seed": 1299410070,
      "version": 383,
      "versionNonce": 600794762,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776855943748,
      "link": null,
      "locked": false,
      "text": "Bridge :- dono abstraction has multiple concreations and Implementation has multiple concreation, so do \ninterchangably vary kar sake, ek sath mene seden ko electric se joda then during runtime or later i cant change it later logically reallife se compare karo\ntoh hence here in this case bridge is better as",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bridge :- dono abstraction has multiple concreations and Implementation has multiple concreation, so do \ninterchangably vary kar sake, ek sath mene seden ko electric se joda then during runtime or later i cant change it later logically reallife se compare karo\ntoh hence here in this case bridge is better as",
      "autoResize": true,
      "lineHeight": 1.25
    },
