      "link": null,
      "locked": false,
      "text": "Critical section, as it requires\nThread-Safety.\nMultiple threads can see nullptr \nand try creating new instance\nbreaking Singleton-Pattern",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Critical section, as it requires Thread-Safety.\nMultiple threads can see nullptr \nand try creating new instance\nbreaking Singleton-Pattern",
      "autoResize": false,
      "lineHeight": 1.25
    },
