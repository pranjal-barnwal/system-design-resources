      "isDeleted": false,
      "boundElements": [],
      "updated": 1779807635993,
      "link": null,
      "locked": false,
      "text": "    static Singleton* getInstance() {\n        if (instance == nullptr) {  // First check (no locking)\n            lock_guard<mutex> lock(mtx);  // Lock only if needed\n            if (instance == nullptr) {  // Second check (after acquiring lock)\n                instance = new Singleton();\n            }\n        }\n        return instance;\n    }",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    static Singleton* getInstance() {\n        if (instance == nullptr) {  // First check (no locking)\n            lock_guard<mutex> lock(mtx);  // Lock only if needed\n            if (instance == nullptr) {  // Second check (after acquiring lock)\n                instance = new Singleton();\n            }\n        }\n        return instance;\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Y_ug1kehD8NYmUQM64qze",
      "type": "text",
      "x": 309.15234375,
      "y": 2273.73828125,
      "width": 462,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
