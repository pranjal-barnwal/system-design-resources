      "link": null,
      "locked": false,
      "text": "Alternate approach is Eager Initialization",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Alternate approach is Eager Initialization",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nLgW0LeQHOT7HtLT0kl3J",
      "type": "text",
      "x": 313.21875,
      "y": 2315.40234375,
      "width": 748,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "aP",
      "roundness": null,
      "seed": 1250406697,
      "version": 322,
      "versionNonce": 449377223,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779807934439,
      "link": null,
      "locked": false,
      "text": "here, we initialize call to creation in main thread flow in advance \nbefore the execution of main() function\n\nPros:\n- avoids locks completely\n\nCons:\n- object will be created, even if it's not used\n- initialization time may be high if object is heavy\n- not used very often",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "here, we initialize call to creation in main thread flow in advance \nbefore the execution of main() function\n\nPros:\n- avoids locks completely\n\nCons:\n- object will be created, even if it's not used\n- initialization time may be high if object is heavy\n- not used very often",
      "autoResize": true,
      "lineHeight": 1.25
    },
