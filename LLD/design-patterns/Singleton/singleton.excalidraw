      "updated": 1781113684566,
      "link": null,
      "locked": false,
      "text": "Locks for Thready-safety, allows only \none Thread to enter at a time,\n\nBut locks are expensive and better if avoided",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Locks for Thready-safety, allows only \none Thread to enter at a time,\n\nBut locks are expensive and better if avoided",
      "autoResize": true,
      "lineHeight": 1.25
    },
