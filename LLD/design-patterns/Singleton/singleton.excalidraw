      "updated": 1779807363907,
      "link": null,
      "locked": false,
      "text": "static Car* getCar() {\n    lock_guard<mutex> lock(mtx);\n    if(instance==nullptr) {\n        instance = new Car();\n    }    \n    return instance;\n}",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "static Car* getCar() {\n    lock_guard<mutex> lock(mtx);\n    if(instance==nullptr) {\n        instance = new Car();\n    }    \n    return instance;\n}",
