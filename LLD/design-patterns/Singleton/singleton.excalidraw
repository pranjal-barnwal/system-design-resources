      "isDeleted": false,
      "boundElements": [],
      "updated": 1781114144703,
      "link": null,
      "locked": false,
      "text": "Logger\n-> helps keep single instance of Logger object\n\nDatabase Connection\n-> connection to DB is expensive operation, \nso different utility classes creating separate objects, \ninstead we can use one shared instance\n\nConfiguration Manager\n-> to keep single source of truth for Environment-Variables",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Logger\n-> helps keep single instance of Logger object\n\nDatabase Connection\n-> connection to DB is expensive operation, \nso different utility classes creating separate objects, \ninstead we can use one shared instance\n\nConfiguration Manager\n-> to keep single source of truth for Environment-Variables",
      "autoResize": true,
      "lineHeight": 1.25
    }
