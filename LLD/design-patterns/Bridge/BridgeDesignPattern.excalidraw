      "isDeleted": false,
      "boundElements": [],
      "updated": 1776855853435,
      "link": null,
      "locked": false,
      "text": "Strategy - during run time i want sedan to have electric engine, and later it to have petrol engine",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Strategy - during run time i want sedan to have electric engine, and later it to have petrol engine",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Wr4XGV_X-D_6nWS7Vwxya",
      "type": "text",
      "x": 354.7259216308594,
      "y": 2528.2999877929688,
      "width": 1480.5986328125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0u",
      "roundness": null,
      "seed": 1299410070,
      "version": 383,
      "versionNonce": 600794762,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776855943748,
      "link": null,
      "locked": false,
      "text": "Bridge :- dono abstraction has multiple concreations and Implementation has multiple concreation, so do \ninterchangably vary kar sake, ek sath mene seden ko electric se joda then during runtime or later i cant change it later logically reallife se compare karo\ntoh hence here in this case bridge is better as",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bridge :- dono abstraction has multiple concreations and Implementation has multiple concreation, so do \ninterchangably vary kar sake, ek sath mene seden ko electric se joda then during runtime or later i cant change it later logically reallife se compare karo\ntoh hence here in this case bridge is better as",
      "autoResize": true,
      "lineHeight": 1.25
    },
