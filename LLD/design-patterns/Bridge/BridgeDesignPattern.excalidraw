      "index": "b0x",
      "roundness": null,
      "seed": 21272586,
      "version": 237,
      "versionNonce": 2133748822,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776856780619,
      "link": null,
      "locked": false,
      "text": "GUI and OS, GUI-> dropdown, Radio button, Text box, OS-> Max, Linux, Windows \nWe need to pair them GUI is abstraction and Impl is like OS, similar to this is great example of the Bridge Design Pattern",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GUI and OS, GUI-> dropdown, Radio button, Text box, OS-> Max, Linux, Windows \nWe need to pair them GUI is abstraction and Impl is like OS, similar to this is great example of the Bridge Design Pattern",
      "autoResize": true,
      "lineHeight": 1.25
    },
