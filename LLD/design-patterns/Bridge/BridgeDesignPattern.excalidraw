      "versionNonce": 273137110,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776856714062,
      "link": null,
      "locked": false,
      "text": "Real World Use case :_ Remote Control System, sony TV is Low level part while remotes are the sony tv remote, screen touch remote, OLED remotte\ni wnat to pair all the remotes with Tvs henvce Bridge design pattern",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Real World Use case :_ Remote Control System, sony TV is Low level part while remotes are the sony tv remote, screen touch remote, OLED remotte\ni wnat to pair all the remotes with Tvs henvce Bridge design pattern",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "J1dvscnoW1uW9yPO6ItN2",
      "type": "text",
      "x": 429.7259216308594,
      "y": 2816.2999877929688,
      "width": 1198.67919921875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
