    {
      "id": "um6FRQ2ZdtF4G7R4jRWMr",
      "type": "text",
      "x": 969.1887197902065,
      "y": 250.11231303418822,
      "width": 163.99990844726562,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 60,
      "groupIds": [],
      "frameId": null,
      "index": "ai",
      "roundness": null,
      "seed": 953200481,
      "version": 80,
      "versionNonce": 1001305999,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781894322086,
      "link": null,
      "locked": false,
      "text": "A* a1 = new A();\nA* a2 = new A();\nA* a3 = new A();",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A* a1 = new A();\nA* a2 = new A();\nA* a3 = new A();",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LVGZalrYmiyVzyxndT1KG",
      "type": "text",
      "x": 509.9381907469236,
      "y": 563.5584254070997,
      "width": 944.6992797851562,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 60,
      "groupIds": [],
      "frameId": null,
      "index": "aj",
      "roundness": null,
      "seed": 1809519585,
      "version": 293,
      "versionNonce": 1977074511,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781940273797,
      "link": null,
      "locked": false,
      "text": "Types of constructor:\n1. Default constructor: provided by default\n    A(){}    \n\n2. Parametrized constructor: overloaded constructor which we create\n    A(int num, string name){}\n\n3. Copy constructor: copy constructor is a constructor that takes an object of the same class \nas a parameter and creates a new object with the same field values\n    A(A a){}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Types of constructor:\n1. Default constructor: provided by default\n    A(){}    \n\n2. Parametrized constructor: overloaded constructor which we create\n    A(int num, string name){}\n\n3. Copy constructor: copy constructor is a constructor that takes an object of the same class \nas a parameter and creates a new object with the same field values\n    A(A a){}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_lXtbLe5zG-pN176Q1Xup",
      "type": "text",
      "x": 567.7716683127151,
      "y": 822.9406019559883,
      "width": 466.9587983630951,
      "height": 292.7641369047619,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "ak",
      "roundness": null,
      "seed": 1571944399,
      "version": 160,
      "versionNonce": 1155792897,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781940275532,
      "link": null,
      "locked": false,
      "text": "public class Person {\n    private String name;\n    private int age;\n    \n    // Regular constructor\n    public Person(String name, int age) {\n        this.name = name;\n        this.age = age;\n    }\n    \n    // COPY CONSTRUCTOR\n    public Person(Person other) {\n        this.name = other.name;   // Copy primitive/String\n        this.age = other.age;\n    }\n}",
      "fontSize": 14.6382068452381,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class Person {\n    private String name;\n    private int age;\n    \n    // Regular constructor\n    public Person(String name, int age) {\n        this.name = name;\n        this.age = age;\n    }\n    \n    // COPY CONSTRUCTOR\n    public Person(Person other) {\n        this.name = other.name;   // Copy primitive/String\n        this.age = other.age;\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Rvab3hcEzAUWRdxiBf5jQ",
      "type": "text",
      "x": 530.8111028365247,
      "y": 1145.7875141583693,
      "width": 947.0194091796875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "al",
      "roundness": null,
      "seed": 33557711,
      "version": 213,
      "versionNonce": 903164303,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781941126449,
      "link": null,
      "locked": false,
      "text": "Basically some object creations are really expensive, so we instead create once & duplicate them;\nlike when involving some DB connection, computing expensive value, etc",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Basically some object creations are really expensive, so we instead create once & duplicate them;\nlike when involving some DB connection, computing expensive value, etc",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "38lWnb8AmdxNcHcDh8Oxm",
      "type": "text",
      "x": 516.2215708136985,
      "y": 1268.288306995996,
      "width": 106.84794616699219,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "am",
      "roundness": null,
      "seed": 371414625,
      "version": 572,
      "versionNonce": 79505487,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781940295470,
      "link": null,
      "locked": false,
      "text": "Example",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fSPGU8sts01t9fbUYtJzI",
      "type": "text",
      "x": 526.2609009678673,
      "y": 1323.1346184714055,
      "width": 1060.4791259765625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "an",
      "roundness": null,
      "seed": 189732591,
      "version": 238,
      "versionNonce": 1090995503,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781940406096,
      "link": null,
      "locked": false,
      "text": "Let's assume, we're having RPG game, and we're having multiple NPCs(Non-Player Characters) roaming in city. \nSo we don't want to create new objects for each from scratch, hence leverage Prototype pattern.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Let's assume, we're having RPG game, and we're having multiple NPCs(Non-Player Characters) roaming in city. \nSo we don't want to create new objects for each from scratch, hence leverage Prototype pattern.",
      "autoResize": true,
      "lineHeight": 1.25
    },
