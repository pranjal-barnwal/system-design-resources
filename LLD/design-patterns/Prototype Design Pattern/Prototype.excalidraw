      "index": "b00",
      "roundness": null,
      "seed": 505132143,
      "version": 301,
      "versionNonce": 761086191,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781942410737,
      "link": null,
      "locked": false,
      "text": "NPC* n1 = new NPC();\nNPC* n2 = n1.clone();\nn2.setAttack(23);",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NPC* n1 = new NPC();\nNPC* n2 = n1.clone();\nn2.setAttack(23);",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ToOTA0K8EdwCpp6ZAM5_n",
      "type": "text",
      "x": 547.7309052312568,
      "y": 1678.81802642935,
      "width": 990.8992919921875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 604465249,
      "version": 239,
      "versionNonce": 507004687,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781942381720,
      "link": null,
      "locked": false,
      "text": "This is really useful when object being create are Same/similar, since created objects will be duplicate.\nWe can still change properties by calling required Setter() functions",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This is really useful when object being create are Same/similar, since created objects will be duplicate.\nWe can still change properties by calling required Setter() functions",
      "autoResize": true,
      "lineHeight": 1.25
    },
