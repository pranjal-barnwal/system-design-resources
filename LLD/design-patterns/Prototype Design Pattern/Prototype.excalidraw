    {
      "id": "tKyFd3LFtJa-3eCrCbk_L",
      "type": "text",
      "x": 1020.7779786273838,
      "y": 1448.8385378530202,
      "width": 529.0924891218358,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 60,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 1678061761,
      "version": 491,
      "versionNonce": 867249519,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781940964643,
      "link": null,
      "locked": false,
      "text": "Any class inherited from Clonable-class, can be cloned.\n\nSo, any client which wants to talk with Clonable, we\ncan instead pass any referenced of inherited classes\nlike NPC instead.\nIn Java such interfaces are called Marker Interfaces\nwhose task is to specify what this is supposed to\ndo. Like here Clonable tells, that this can be cloned.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Any class inherited from Clonable-class, can be cloned.\n\nSo, any client which wants to talk with Clonable, we can instead pass any referenced of inherited classes like NPC instead.\nIn Java such interfaces are called Marker Interfaces whose task is to specify what this is supposed to do. Like here Clonable tells, that this can be cloned.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "8e78It7YWBOhb-G3Mg-Xu",
      "type": "text",
      "x": 592.9633811109497,
      "y": 1758.533673382389,
      "width": 208.85987854003906,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
