    {
      "id": "ivy10uk4Z9IRd7W7u-rCG",
      "type": "text",
      "x": 1126.6261834068587,
      "y": 379.5143770843938,
      "width": 755.3995971679688,
      "height": 175,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "#fff9db",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 1176714578,
      "version": 404,
      "versionNonce": 2065911058,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781331437571,
      "link": null,
      "locked": false,
      "text": "Whenever any client request for some amount to ATM, request goes through \nChain of Resources until request is not resolved.\n\nHere let's say request comes for withdrawing ₹2700.\n- R1 picks 2x1000 notes, so 2000\n- R2 picks 1x500 note, so another 500\n- R3 finally picks 2x100 note, so another 200",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Whenever any client request for some amount to ATM, request goes through \nChain of Resources until request is not resolved.\n\nHere let's say request comes for withdrawing ₹2700.\n- R1 picks 2x1000 notes, so 2000\n- R2 picks 1x500 note, so another 500\n- R3 finally picks 2x100 note, so another 200",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tIagdaV4vvTzwLkTHLdUP",
      "type": "text",
      "x": 1161.0585514948918,
      "y": 611.9026442307693,
      "width": 677.859619140625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "av",
      "roundness": null,
      "seed": 1826454906,
      "version": 169,
      "versionNonce": 1275029690,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781334524265,
      "link": null,
      "locked": false,
      "text": "This helps to avoid breaking OCP of SOLID as if we would have put \neverything in just 1 function, then for updating logic, \nwe would need to change entire code",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This helps to avoid breaking OCP of SOLID as if we would have put \neverything in just 1 function, then for updating logic, \nwe would need to change entire code",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
