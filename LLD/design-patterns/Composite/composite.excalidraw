      "isDeleted": false,
      "boundElements": [],
      "updated": 1782191673451,
      "link": null,
      "locked": false,
      "text": "Composite class has both IS-A and HAS-A relation\nsimilar to Decorator design pattern",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Composite class has both IS-A and HAS-A relation\nsimilar to Decorator design pattern",
