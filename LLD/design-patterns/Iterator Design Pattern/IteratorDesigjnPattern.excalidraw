      "updated": 1782326131521,
      "link": null,
      "locked": false,
      "text": "Alll good Languages supports the iterator and we can also make our own desing our own iterator!!! To traverse the List we use Iterator",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Alll good Languages supports the iterator and we can also make our own desing our own iterator!!! To traverse the List we use Iterator",
      "autoResize": true,
