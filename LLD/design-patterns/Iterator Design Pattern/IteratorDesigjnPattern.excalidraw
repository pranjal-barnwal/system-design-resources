      "index": "a9",
      "roundness": null,
      "seed": 1332113939,
      "version": 502,
      "versionNonce": 505843425,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781353509079,
      "link": null,
      "locked": false,
      "text": "For any traverse logic we must use the Iterator Class only that has the all the logic of traversal includind all the edge cases. \nit makes code more verbose but it helps in follow SRP, if in future we change the undelined Data strucure like List to LinkedList then \nit doesnt affect the iterator, we just need to update the iterator only!! simple!! ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For any traverse logic we must use the Iterator Class only that has the all the logic of traversal includind all the edge cases. \nit makes code more verbose but it helps in follow SRP, if in future we change the undelined Data strucure like List to LinkedList then \nit doesnt affect the iterator, we just need to update the iterator only!! simple!! ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
