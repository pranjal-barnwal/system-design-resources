      "seed": 1172189107,
      "version": 397,
      "versionNonce": 982132641,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781353640719,
      "link": null,
      "locked": false,
      "text": "We need diffrent class called iterator which has hasNext() and next() method that actually traverses, because we need to keep the \ntravesing logic in the diffrent classes and dont break the SRP and follow the SRP using traverse logic iterator class .",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We need diffrent class called iterator which has hasNext() and next() method that actually traverses, because we need to keep the \ntravesing logic in the diffrent classes and dont break the SRP and follow the SRP using traverse logic iterator class .",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TGGGtE_PO4Wc4KQh3Gf5a",
      "type": "text",
      "x": 104.750169983572,
      "y": 902.0232154605759,
      "width": 1314.459228515625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
