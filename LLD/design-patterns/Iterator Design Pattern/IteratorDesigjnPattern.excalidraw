      "index": "a3",
      "roundness": null,
      "seed": 628919827,
      "version": 345,
      "versionNonce": 1421163054,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782326131521,
      "link": null,
      "locked": false,
      "text": "When ever we need to iterate throgh the object , means we need to traverse  the custom object, just like LinkedListNode, BinaryTreeNode, Song\netc we need to traverse this the object lists \nlike List<songs> ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When ever we need to iterate throgh the object , means we need to traverse  the custom object, just like LinkedListNode, BinaryTreeNode, Song\netc we need to traverse this the object lists \nlike List<songs> ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C59G5ochUyO0Y264cGIjg",
      "type": "text",
      "x": 97.4396019476344,
      "y": 376.6630712777663,
      "width": 1339.9591064453125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
