    },
    {
      "id": "sLFlwV4_bWPyisWDD1IeY",
      "type": "text",
      "x": 101.43070945642137,
      "y": 432.2016210473226,
      "width": 1509.4991455078125,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1854053309,
      "version": 782,
      "versionNonce": 1846740654,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782326131521,
      "link": null,
      "locked": false,
      "text": "Why we need iternator:- We have Playlist of songs, song has multiple fields, in playlist we have List<Songs>, in playlist, we have the playEntirePlayList(){} \nfunction and now this function shoudl know that how to traverse the whole playlist, now this is breaking the SRP \nthat storing the Songs list and its traverse logic both in the same class called PlayList is breaking gthe SRP",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why we need iternator:- We have Playlist of songs, song has multiple fields, in playlist we have List<Songs>, in playlist, we have the playEntirePlayList(){} \nfunction and now this function shoudl know that how to traverse the whole playlist, now this is breaking the SRP \nthat storing the Songs list and its traverse logic both in the same class called PlayList is breaking gthe SRP",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "g2NIC_D8Xj4KPLdMdOu24",
      "type": "text",
      "x": 99.08917048484943,
      "y": 813.9076303690935,
      "width": 1299.459228515625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
