      "seed": 884545094,
      "version": 189,
      "versionNonce": 719567242,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782211094385,
      "link": null,
      "locked": false,
      "text": "So to make the object light weight break it in to the 2 things \n    1. Instrinsic Properties \n    2. Extrinsic Properties",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So to make the object light weight break it in to the 2 things \n    1. Instrinsic Properties \n    2. Extrinsic Properties",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Y2UpQ6DoE_KlmMTkOCZt_",
      "type": "text",
      "x": 378.74893333798354,
      "y": 680.6338327445236,
      "width": 1210.979248046875,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
