      "isDeleted": false,
      "boundElements": [],
      "updated": 1782211094385,
      "link": null,
      "locked": false,
      "text": "Eg. In Space ship shooting astroid game we need milliosn of \nastroid instead of creating new we can reuse them ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Eg. In Space ship shooting astroid game we need milliosn of \nastroid instead of creating new we can reuse them ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gFUuQ9N4gp2wLkrPWDPFD",
      "type": "text",
      "x": 946.2103794642858,
      "y": 293.6523437500001,
      "width": 697.4395751953125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
