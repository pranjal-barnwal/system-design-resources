      "versionNonce": 1450091210,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782211094385,
      "link": null,
      "locked": false,
      "text": "To make the object light weight like in astroid class size is 1MB and\nwe need to create millions of astroid them memory will not be sufficient",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To make the object light weight like in astroid class size is 1MB and\nwe need to create millions of astroid them memory will not be sufficient",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "lgPHLaWbdclfNNCBeWaH0",
      "type": "text",
      "x": 349.2103794642858,
      "y": 371.6523437500001,
      "width": 618.5796508789062,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
