    {
      "id": "CH8JjN9pe8K_jiw1E8V3A",
      "type": "text",
      "x": 288.68843431719733,
      "y": 2775.7613364771796,
      "width": 653.779541015625,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 828058945,
      "version": 781,
      "versionNonce": 2140763164,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781813045763,
      "link": null,
      "locked": false,
      "text": "Mediator focuses on 2 collegues ko apas me baat \nkarane ke liye like. Bidirectional-Channel\nto help the 2 collegue talk to each other simple!!\nBy simple having centralized mediator \n\nWhile Observer-Pattern :- we have the observable that notifies\nall the observers when its state is changed !! Onedirection-Channel\n2 observa ko apas me communidcate nahi karta ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mediator focuses on 2 collegues ko apas me baat \nkarane ke liye like. Bidirectional-Channel\nto help the 2 collegue talk to each other simple!!\nBy simple having centralized mediator \n\nWhile Observer-Pattern :- we have the observable that notifies\nall the observers when its state is changed !! Onedirection-Channel\n2 observa ko apas me communidcate nahi karta ",
      "autoResize": true,
      "lineHeight": 1.25
    },
