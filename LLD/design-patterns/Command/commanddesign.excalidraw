      "link": null,
      "locked": false,
      "text": "ICommand dont have has a but concreate has\nhas a relationship, it depends on the intention\nhere the intension of execution is on concreat\ncommand hence it has the Light class\nFollowing the LSP, thats why we did the \ncomposition has a relation at the concreate class level",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ICommand dont have has a but concreate has\nhas a relationship, it depends on the intention\nhere the intension of execution is on concreat\ncommand hence it has the Light class\nFollowing the LSP, thats why we did the \ncomposition has a relation at the concreate class level",
      "autoResize": true,
