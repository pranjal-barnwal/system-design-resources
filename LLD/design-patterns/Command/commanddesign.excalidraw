  "elements": [
    {
      "id": "goOmoRO3p4RF4OSnMlMo4",
      "type": "text",
      "x": 264,
      "y": 74.83333333333331,
      "width": 1304.8145548502605,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 1314111360,
      "version": 288,
      "versionNonce": 2011162752,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776148109279,
      "link": null,
      "locked": false,
      "text": "COMMAND Design Pattern :- Encaptulate a request as an object, there by letting you\nparametetize clients with diffrent request, queue or log request and support undoable\noperations\n",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "COMMAND Design Pattern :- Encaptulate a request as an object, there by letting you parametetize clients with diffrent request, queue or log request and support undoable operations\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ZIq5HKbLyt1xlSQwfXned",
      "type": "text",
      "x": 252,
      "y": 260,
      "width": 1124.83935546875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 353013632,
      "version": 347,
      "versionNonce": 2038603648,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776146320636,
      "link": null,
      "locked": false,
      "text": "We have source and reciever, we want them to loosly coupled, for that we add the command in the middle \nmeans now source will send a request to command and its commands duty to execute it and send it to reciever get\nthe response and parse the response to source again!!!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have source and reciever, we want them to loosly coupled, for that we add the command in the middle \nmeans now source will send a request to command and its commands duty to execute it and send it to reciever get\nthe response and parse the response to source again!!!",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iW5QvB9YQVFrDq7zMfHV4",
      "type": "text",
      "x": 256.6363636363637,
      "y": 359.1818181818182,
      "width": 1275.3990478515625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 2089277568,
      "version": 399,
      "versionNonce": 1270439808,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776147083375,
      "link": null,
      "locked": false,
      "text": "Remote dont have to directly connect to apliences like light, fan, AC, heater etc but it should go thorgh command like ICommand\nto be loosely coupled with them, to extend the bahviour in future and fix the OCP principle!! basically here client is delegating its \nrequest to command to do stuffs!! simlpe!\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Remote dont have to directly connect to apliences like light, fan, AC, heater etc but it should go thorgh command like ICommand\nto be loosely coupled with them, to extend the bahviour in future and fix the OCP principle!! basically here client is delegating its \nrequest to command to do stuffs!! simlpe!\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
