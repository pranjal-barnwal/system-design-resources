    {
      "id": "6uhrf5Wb7gROThQNhWklR",
      "type": "text",
      "x": 524.4207844540701,
      "y": 1543.4701922527966,
      "width": 556.5644459131531,
      "height": 225,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "aa",
      "roundness": null,
      "seed": 1102743919,
      "version": 476,
      "versionNonce": 662130081,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781981367913,
      "link": null,
      "locked": false,
      "text": "When performing CRUD operations on DB like updating\nroll_no & name for Pranjal and the transaction fails in\nb/w; this will lead to Inconsistent-state.\n\nIn such situations, we roll back to previous valid state,\nso we can rerun the query; basically Atomicity.\n\nWe want all the operations in a query to be perfomed or\nnone, so to remain in Consistent-state.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When performing CRUD operations on DB like updating roll_no & name for Pranjal and the transaction fails in b/w; this will lead to Inconsistent-state.\n\nIn such situations, we roll back to previous valid state, so we can rerun the query; basically Atomicity.\n\nWe want all the operations in a query to be perfomed or none, so to remain in Consistent-state.",
      "autoResize": false,
      "lineHeight": 1.25
    },
