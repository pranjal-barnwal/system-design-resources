    {
      "id": "tORJHp3FghQ-PYEpxsYzd",
      "type": "text",
      "x": 187.67898001788353,
      "y": 2210.963440985469,
      "width": 733.5509674171071,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 285529551,
      "version": 526,
      "versionNonce": 975134646,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782325096288,
      "link": null,
      "locked": false,
      "text": "Here's a rough workflow of DB Transaction with snapshots & rollback.\nRollback which requires knowledge & storage of previous Snapshots is\nhandled by Memento-pattern. In React.js also we have useMem() hook\n\n- whenever we're performing, before any CRUD operation it takes\nSnapshot/Memento in Caretaker before Transaction\n- transaction gets committed only when it's in Valid-state",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here's a rough workflow of DB Transaction with snapshots & rollback.\nRollback which requires knowledge & storage of previous Snapshots is handled by Memento-pattern. In React.js also we have useMem() hook\n\n- whenever we're performing, before any CRUD operation it takes Snapshot/Memento in Caretaker before Transaction\n- transaction gets committed only when it's in Valid-state",
      "autoResize": false,
      "lineHeight": 1.25
    },
