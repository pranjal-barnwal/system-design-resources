    {
      "id": "MHhOXboMwO_zvLzXIPGk8",
      "type": "text",
      "x": 828.6518070764773,
      "y": 2871.3349214329332,
      "width": 412.6924890709727,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f3f0ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b0c",
      "roundness": null,
      "seed": 1488425839,
      "version": 693,
      "versionNonce": 1743701775,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781984758797,
      "link": null,
      "locked": false,
      "text": "In our simple CRUD DB application, we\ndon't need multiple Memento / Snapshots,\ninstead we just need one to restore to\nlast saved snapshot before crash if it\noccurs. In committing older Memento is\ndeleted and replaced with new one.\n\nBut if we wanted to have multiple\nsnapshots, then we will require Vector of\nMemento in Caretaker.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In our simple CRUD DB application, we don't need multiple Memento / Snapshots, instead we just need one to restore to last saved snapshot before crash if it occurs. In committing older Memento is deleted and replaced with new one.\n\nBut if we wanted to have multiple snapshots, then we will require Vector of Memento in Caretaker.",
      "autoResize": false,
      "lineHeight": 1.25
    },
