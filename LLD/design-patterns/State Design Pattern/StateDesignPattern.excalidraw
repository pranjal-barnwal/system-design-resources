    {
      "id": "fnIK7pG6mfXCMiASzOEs2",
      "type": "text",
      "x": 356.18507000402883,
      "y": -295.0758460918614,
      "width": 1085.1591796875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1628969748,
      "version": 513,
      "versionNonce": 1663828476,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781697877242,
      "link": null,
      "locked": false,
      "text": "In application our user or object goes throgh diffrent phases or states, like in vending machine it goes thorgh \nlike vendin Machine HasCoinState, NoCoinState, DespenseItem, SoldOutState etc",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In application our user or object goes throgh diffrent phases or states, like in vending machine it goes thorgh \nlike vendin Machine HasCoinState, NoCoinState, DespenseItem, SoldOutState etc",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "df-rxeDveh0XHW-PJsb1k",
      "type": "text",
      "x": 349.3131295326349,
      "y": -216.74841357775983,
      "width": 1100.619140625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 1377090988,
      "version": 712,
      "versionNonce": 2110219260,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781698333710,
      "link": null,
      "locked": false,
      "text": "Basicallt ek machine or algorith ka step by step pura working ko states me devide kardo ye states finite hongi \nand ye states simple ek dusre pe dependend ki iske baad hi ye hoga like that then use the state Design pattern\nalso helps to keep system Loosely-coupled",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Basicallt ek machine or algorith ka step by step pura working ko states me devide kardo ye states finite hongi \nand ye states simple ek dusre pe dependend ki iske baad hi ye hoga like that then use the state Design pattern\nalso helps to keep system Loosely-coupled",
      "autoResize": true,
      "lineHeight": 1.25
    },
