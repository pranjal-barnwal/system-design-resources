      "link": null,
      "locked": false,
      "text": "Adaptor Design Pattern :- Simple connecting the 2 incompatible interfaces we add\nadaptor class btw them simple just like adaptor works, socket adaptor or anyother\nadaptor to make 2 impatible things compatible",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Adaptor Design Pattern :- Simple connecting the 2 incompatible interfaces we add adaptor class btw them simple just like adaptor works, socket adaptor or anyother adaptor to make 2 impatible things compatible",
      "autoResize": false,
      "lineHeight": 1.25
    },
