      "boundElements": [],
      "updated": 1776009636503,
      "link": null,
      "locked": false,
      "text": "Factory method :- This is Design pattern, this say above the simple factory extend the \nfactories simple means there can be multiple concreate factories like, singBurger, KingBurger etc \nmu;tiple concreate implementation of diffrent types of factories",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Factory method :- This is Design pattern, this say above the simple factory extend the \nfactories simple means there can be multiple concreate factories like, singBurger, KingBurger etc \nmu;tiple concreate implementation of diffrent types of factories",
      "autoResize": true,
      "lineHeight": 1.25
    },
