      "index": "b15",
      "roundness": null,
      "seed": 1250832226,
      "version": 359,
      "versionNonce": 498482110,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776010424603,
      "link": null,
      "locked": false,
      "text": "Abstract Factory Method :- This is design pattern , in factory one factory can just create one product like burger\nbut here we are saying a factory can create multiple products then it is abstract factory like a singhBurger factory\ncan create multple products like burger also garlic bread or fries!",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Abstract Factory Method :- This is design pattern , in factory one factory can just create one product like burger\nbut here we are saying a factory can create multiple products then it is abstract factory like a singhBurger factory\ncan create multple products like burger also garlic bread or fries!",
      "autoResize": true,
      "lineHeight": 1.25
    },
