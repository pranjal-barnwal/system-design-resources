    {
      "id": "EUbqe67a7SuF114wyie4u",
      "type": "text",
      "x": 71.67411041259766,
      "y": 2095.47265625,
      "width": 195.157470703125,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 223502638,
      "version": 1168,
      "versionNonce": 241145198,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024688310,
      "link": null,
      "locked": false,
      "text": "3. Hard-Coding:",
      "fontSize": 26.8,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Hard-Coding:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WoGLusOnfpauPdqx_P-6j",
      "type": "text",
      "x": 73.578125,
      "y": 2153.9375,
      "width": 868.154296875,
      "height": 54,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 1838051502,
      "version": 285,
      "versionNonce": 516547378,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024872219,
      "link": null,
      "locked": false,
      "text": "Suppose we're running a hardware shop and we have Hard-Coded gst rate on it to be 18%\neverywhere in code, which is correct for now. But what if Gov changes rate to 25% in future?",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Suppose we're running a hardware shop and we have Hard-Coded gst rate on it to be 18% everywhere in code, which is correct for now. But what if Gov changes rate to 25% in future?",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "MzwIBmJv9ypbItCS8EdQ3",
      "type": "text",
      "x": 75.57512435913083,
      "y": 2232.1953125,
      "width": 863.6778762817383,
      "height": 99.484375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 1103489006,
      "version": 552,
      "versionNonce": 2134194414,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782025003705,
      "link": null,
      "locked": false,
      "text": "Better way to deal with this is using Constants, or through Configuration file or\nexternal sources.\nHard-coding only makes sense for values which we're sure are not going to change in\nfuture like value of Pi.",
      "fontSize": 19.896875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Better way to deal with this is using Constants, or through Configuration file or external sources.\nHard-coding only makes sense for values which we're sure are not going to change in future like value of Pi.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "5CYwsCQDFtUdZ4T1RwDx9",
      "type": "text",
      "x": 83.40478348405395,
      "y": 2627.8752675513697,
      "width": 444.4776611328125,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "ag",
      "roundness": null,
      "seed": 983118194,
      "version": 1360,
      "versionNonce": 1909822578,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782025260006,
      "link": null,
      "locked": false,
      "text": "4. Gold-Plating (Over-engineering):",
      "fontSize": 26.8,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Gold-Plating (Over-engineering):",
