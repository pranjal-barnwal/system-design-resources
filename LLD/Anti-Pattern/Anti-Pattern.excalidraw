    {
      "id": "il6z2G3TxkKgbkGqDC8gm",
      "type": "text",
      "x": 85.18230287363178,
      "y": 3544.8056652208124,
      "width": 863.6778762817383,
      "height": 99.484375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 557647986,
      "version": 1729,
      "versionNonce": 1275545518,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782026631158,
      "link": null,
      "locked": false,
      "text": "Problem with this approach is that if the base logic of it changes, then we will need to\ngo individually in each function and update.\nSo instead we extract-out the common code-block & create separate utility class and\nfrom that single entry use it anywhere.",
      "fontSize": 19.896875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem with this approach is that if the base logic of it changes, then we will need to go individually in each function and update.\nSo instead we extract-out the common code-block & create separate utility class and from that single entry use it anywhere.",
      "autoResize": false,
      "lineHeight": 1.25
    },
