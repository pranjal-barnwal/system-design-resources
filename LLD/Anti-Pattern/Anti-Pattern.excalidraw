      "updated": 1782026270173,
      "link": null,
      "locked": false,
      "text": "Sometimes multiple functions utilize same parts of code-blocks and there we start\nrepeating code & Copy-Pasting. This in turn breaks DRY (Don't Repeat Yourself)\nprinciple.",
      "fontSize": 19.896875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sometimes multiple functions utilize same parts of code-blocks and there we start repeating code & Copy-Pasting. This in turn breaks DRY (Don't Repeat Yourself) principle.",
      "autoResize": false,
      "lineHeight": 1.25
    },
