      "versionNonce": 367910062,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024633625,
      "link": null,
      "locked": false,
      "text": "Spaghetti code has:\n- Over-complicated code with no entry/exit point\n- no clear structure\n- tight coupling",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Spaghetti code has:\n- Over-complicated code with no entry/exit point\n- no clear structure\n- tight coupling",
      "autoResize": false,
      "lineHeight": 1.25
