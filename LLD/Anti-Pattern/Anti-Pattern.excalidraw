      "updated": 1782026765575,
      "link": null,
      "locked": false,
      "text": "6. Constructor Overloading:",
      "fontSize": 26.8,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "6. Constructor Overloading:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wUBS2Zs0oEWCH-cSPAd0p",
      "type": "text",
      "x": 78.19308563761004,
      "y": 3818.950506350633,
      "width": 863.6778762817383,
      "height": 49.7421875,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b0P",
      "roundness": null,
      "seed": 1647703726,
      "version": 1522,
      "versionNonce": 699762926,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782026808339,
      "link": null,
      "locked": false,
      "text": "Having so many constructors for targetting each-case is not optimal.\nWe actually solved this problem already previously using Builder design pattern.",
      "fontSize": 19.896875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Having so many constructors for targetting each-case is not optimal.\nWe actually solved this problem already previously using Builder design pattern.",
      "autoResize": false,
      "lineHeight": 1.25
    },
