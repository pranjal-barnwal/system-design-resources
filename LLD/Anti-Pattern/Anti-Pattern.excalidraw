    {
      "id": "gOwhHERLbt4RGs8GNlBQT",
      "type": "text",
      "x": 294.07073974609375,
      "y": 870.6484375,
      "width": 698.610870361328,
      "height": 54,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "aB",
      "roundness": null,
      "seed": 2126759986,
      "version": 259,
      "versionNonce": 1322439474,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024241472,
      "link": null,
      "locked": false,
      "text": "In past problems, also we created one main Orchestration class/object, does\nthat make it God Object?",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In past problems, also we created one main Orchestration class/object, does that make it God Object?",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "mRUYVoQgwXJtOpUDOE24R",
      "type": "text",
      "x": 299.553939819336,
      "y": 928.921875,
      "width": 698.610870361328,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "aC",
      "roundness": null,
      "seed": 1344778990,
      "version": 556,
      "versionNonce": 1396022514,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024241472,
      "link": null,
      "locked": false,
      "text": "Answer is it depends.\nIf the task of Orchestration object is only to delegate, then it's not\nGod object, since it's not by itself performing operations.\n\nBut if it's perfoming some operations before delegating, then it's\nindeed a God-Object.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Answer is it depends.\nIf the task of Orchestration object is only to delegate, then it's not God object, since it's not by itself performing operations.\n\nBut if it's perfoming some operations before delegating, then it's indeed a God-Object.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "A228FVfSSbmJSYaeKGXp7",
      "type": "text",
      "x": 85.67578125,
      "y": 1014.96875,
      "width": 171.1598663330078,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "aD",
      "roundness": null,
      "seed": 1979210482,
      "version": 92,
      "versionNonce": 1545154226,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024241472,
      "link": null,
      "locked": false,
      "text": "Breaks SRP,\nintroduces Errors",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Breaks SRP,\nintroduces Errors",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GrqCOEaFX0cyHCnx-YQNa",
      "type": "text",
      "x": 112.24609375,
      "y": 1119.27734375,
      "width": 775.579345703125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "aF",
      "roundness": null,
      "seed": 514304366,
      "version": 201,
      "versionNonce": 774146162,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782024241472,
      "link": null,
      "locked": false,
      "text": "This is why, we always prefer Orchestration service to only work as delegation.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This is why, we always prefer Orchestration service to only work as delegation.",
      "autoResize": true,
      "lineHeight": 1.25
    },
