    {
      "id": "p5jXPTxS2fKTRyVX8HacI",
      "type": "text",
      "x": 82.051258776939,
      "y": 2676.0828339041095,
      "width": 863.6778762817383,
      "height": 149.2265625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 372217582,
      "version": 1011,
      "versionNonce": 2112899698,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782026027003,
      "link": null,
      "locked": false,
      "text": "If we try to be Perfectionist, use all SOLID principles, design-patterns, OOPs concepts,\nhandling all edge cases which may not even exist; then the actual application becomes\nOver-engineered & Over-complicated.\n\nLike making every functionality Strategy, whereas we discussed there that only\nfunctionalities which are supposed to change, should only be Strategy.",
      "fontSize": 19.896875,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we try to be Perfectionist, use all SOLID principles, design-patterns, OOPs concepts, handling all edge cases which may not even exist; then the actual application becomes Over-engineered & Over-complicated.\n\nLike making every functionality Strategy, whereas we discussed there that only functionalities which are supposed to change, should only be Strategy.",
      "autoResize": false,
      "lineHeight": 1.25
    },
