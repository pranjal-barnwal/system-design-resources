    {
      "id": "HkvClRHFtxqujTOlT9oGS",
      "type": "text",
      "x": 80.03906405555733,
      "y": 182.4756365642442,
      "width": 105.96713256835938,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
