    {
      "id": "-quYmq11cpRN5nqZf0jPa",
      "type": "text",
      "x": 67.64990722906711,
      "y": 4198.033674157978,
      "width": 415.26568603515625,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
