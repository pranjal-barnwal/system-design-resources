      "lineHeight": 1.25
    },
    {
      "id": "dhL-uaytAP62_qF6ALzSP",
      "type": "text",
      "x": 102.5859375,
      "y": 2357.32421875,
      "width": 293.484375,
      "height": 76.22970779220776,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 60,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 1818326958,
      "version": 251,
      "versionNonce": 637719534,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782025117115,
      "link": null,
      "locked": false,
      "text": "calculateTotal(int basePrice) {\n    int gstRate = 0.18;\n    return basePrice * (1+gstRate);\n}",
      "fontSize": 15.24594155844156,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "calculateTotal(int basePrice) {\n    int gstRate = 0.18;\n    return basePrice * (1+gstRate);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fZwMWb6Lu2caVekrbjhHM",
      "type": "text",
      "x": 473.46875,
      "y": 2354.0960836038957,
      "width": 318.51556396484375,
      "height": 76.2297077922078,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 60,
      "groupIds": [],
      "frameId": null,
      "index": "ai",
      "roundness": null,
      "seed": 49908082,
      "version": 343,
      "versionNonce": 967930866,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782025132578,
      "link": null,
      "locked": false,
      "text": "calculateTotal(int basePrice) {\n    int gstRate = process.env.gstRate;\n    return basePrice * (1+gstRate);\n}",
      "fontSize": 15.24594155844156,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "calculateTotal(int basePrice) {\n    int gstRate = process.env.gstRate;\n    return basePrice * (1+gstRate);\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
