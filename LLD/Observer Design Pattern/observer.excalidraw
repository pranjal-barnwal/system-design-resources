      "seed": 844748481,
      "version": 370,
      "versionNonce": 1542037039,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776014230259,
      "link": null,
      "locked": false,
      "text": "When one object changes other object has to know that this object \nis changed, also the changing object publisher has to pass the information to\nall the objects that needs to know that object is changed!!! basically youtube publisher \nsubscriber like a youtube uploades a video then all the subscriber should be notified!! ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When one object changes other object has to know that this object \nis changed, also the changing object publisher has to pass the information to\nall the objects that needs to know that object is changed!!! basically youtube publisher \nsubscriber like a youtube uploades a video then all the subscriber should be notified!! ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
