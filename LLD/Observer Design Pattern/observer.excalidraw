    {
      "id": "CjXuBI6xpoq2JkzybIFEw",
      "type": "text",
      "x": 343,
      "y": 310,
      "width": 865.3394165039062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
