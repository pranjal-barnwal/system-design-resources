      "updated": 1777201220887,
      "link": null,
      "locked": false,
      "text": "Mediator vs Observer :- \nlooks similar but this is Intent ka farq hai simpl!!!\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mediator vs Observer :- \nlooks similar but this is Intent ka farq hai simpl!!!\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "CH8JjN9pe8K_jiw1E8V3A",
      "type": "text",
      "x": 533.7159118652344,
      "y": 1933.7999877929688,
      "width": 613.7996215820312,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 828058945,
      "version": 467,
      "versionNonce": 1323205985,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777202016954,
      "link": null,
      "locked": false,
      "text": "Mediator focuses on 2 collegues ko apas me baat \nkarane ke liye like \nto help the 2 collegue talk to each other simple!!\nBy simple having centralized mediator \n\nWhile observer Pattern :- we have the observable that notifies\nall the observers when its state is changed !!\n2 observa ko apas me communidcate nahi karta ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mediator focuses on 2 collegues ko apas me baat \nkarane ke liye like \nto help the 2 collegue talk to each other simple!!\nBy simple having centralized mediator \n\nWhile observer Pattern :- we have the observable that notifies\nall the observers when its state is changed !!\n2 observa ko apas me communidcate nahi karta ",
      "autoResize": true,
      "lineHeight": 1.25
    },
