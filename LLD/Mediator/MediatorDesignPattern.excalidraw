      "isDeleted": false,
      "boundElements": null,
      "updated": 1777200394555,
      "link": null,
      "locked": false,
      "text": "Same application we can say about the Airport \nthere multiple airplanes, halicopter, cargoplane, military aircarftas needs to land\nnow each cannot have contact of all others, so they contact a single system that is\nATC air traffic controller - Simple - ATC acts as a mediator simple!!!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Same application we can say about the Airport \nthere multiple airplanes, halicopter, cargoplane, military aircarftas needs to land\nnow each cannot have contact of all others, so they contact a single system that is\nATC air traffic controller - Simple - ATC acts as a mediator simple!!!",
      "autoResize": true,
      "lineHeight": 1.25
    },
