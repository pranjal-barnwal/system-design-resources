    },
    {
      "id": "Gz9y52_jxuY11bLGDwA1m",
      "type": "text",
      "x": -89.0500510492119,
      "y": 379.77314682409764,
      "width": 924.4615478515625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 474303339,
      "version": 467,
      "versionNonce": 671833477,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782043800139,
      "link": null,
      "locked": false,
      "text": "We have already used this pattern unknowingly multiple times in past.\nIt states that we should be avoiding Null-checks in our code.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have already used this pattern unknowingly multiple times in past.\nIt states that we should be avoiding Null-checks in our code.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "E5s2uv9h_HIsxN4a5bfrm",
      "type": "text",
      "x": -3.79296875,
      "y": 446.9749898538962,
      "width": 142.49380493164062,
      "height": 76.2297077922078,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "#ffec99",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "a4",
      "roundness": null,
      "seed": 1081645835,
      "version": 359,
      "versionNonce": 861377285,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782038752588,
      "link": null,
      "locked": false,
      "text": "if(obj == null) {\n    ---\n    obj.m1();\n}",
      "fontSize": 15.24594155844156,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if(obj == null) {\n    ---\n    obj.m1();\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yFwCeStS093pAyUo1IFSy",
      "type": "text",
      "x": -95.52374267578125,
      "y": 557.2421875,
      "width": 924.4615478515625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 243070251,
      "version": 866,
      "versionNonce": 303541611,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782043308460,
      "link": null,
      "locked": false,
      "text": "The reason we check for null-pointer is bcuz otherwise calling methods on Null object will give\nus exception and break our code.\n\nIn OOPs we learnt that we tend to replace conditional if-else with Polymorphism.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The reason we check for null-pointer is bcuz otherwise calling methods on Null object will give us exception and break our code.\n\nIn OOPs we learnt that we tend to replace conditional if-else with Polymorphism.",
      "autoResize": false,
      "lineHeight": 1.25
    },
