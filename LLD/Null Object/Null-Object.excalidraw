    {
      "id": "O7rzgRkQIffZEUu4vUHS2",
      "type": "text",
      "x": -87.96616791470728,
      "y": 315.1860777962367,
      "width": 105.96713256835938,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
