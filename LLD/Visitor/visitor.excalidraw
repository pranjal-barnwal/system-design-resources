      "seed": 774872782,
      "version": 801,
      "versionNonce": 377272082,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781962945622,
      "link": null,
      "locked": false,
      "text": "Visitor vs Strategy:",
      "fontSize": 26.8,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Visitor vs Strategy:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VBeHgICIaZfS5q_e09_zq",
      "type": "text",
      "x": 18.174025024101297,
      "y": 3376.16910105829,
      "width": 930.2717152388018,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b19",
      "roundness": null,
      "seed": 1355438222,
      "version": 314,
      "versionNonce": 1237924622,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781962772683,
      "link": null,
      "locked": false,
      "text": "Double-Dispatch means two references (ref1 & ref2) decides which exact method will be called.\n\nLike in below example DocumentType and Visiotr called on that type together decide the\nactual exact method which is to be called.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Double-Dispatch means two references (ref1 & ref2) decides which exact method will be called.\n\nLike in below example DocumentType and Visiotr called on that type together decide the actual exact method which is to be called.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "HDPBDxxi82jyM1U2b0w_u",
      "type": "text",
      "x": 78.60717170493933,
      "y": 3490.8984948696457,
      "width": 462,
      "height": 75,
      "angle": 0,
      "strokeColor": "#846358",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b1A",
      "roundness": null,
      "seed": 1442264210,
      "version": 212,
      "versionNonce": 2004698386,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781962775164,
      "link": null,
      "locked": false,
      "text": "DocumentElement file = new TextFile();\nfile1.accept(new SizeCalculatorVisitor());\nfile1.accept(new CompressVisitor());",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DocumentElement file = new TextFile();\nfile1.accept(new SizeCalculatorVisitor());\nfile1.accept(new CompressVisitor());",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_U3pDPpFEa-FDmWm0TgM0",
      "type": "text",
      "x": 5.2082649760116055,
      "y": 3602.8373576470285,
      "width": 955.2627875287031,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b1B",
      "roundness": null,
      "seed": 1886705166,
      "version": 190,
      "versionNonce": 1600816654,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781962936874,
      "link": null,
      "locked": false,
      "text": "Similarly there is also Single-Dispatch, where just one reference is enough to decide and this is\nalso something which we had been using generally till now.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Similarly there is also Single-Dispatch, where just one reference is enough to decide and this is also something which we had been using generally till now.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "BvnLdq7mzyQ3WtI-rLc2T",
      "type": "rectangle",
      "x": 425.2080625146813,
      "y": 4086.4975391472403,
