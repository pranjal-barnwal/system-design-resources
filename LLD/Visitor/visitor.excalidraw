    {
      "id": "_INF3LZ69uIJX_2OkxcFC",
      "type": "text",
      "x": 335.8326935379602,
      "y": 4306.311669749036,
      "width": 157.18631364971105,
      "height": 28.552446946168,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
