    {
      "id": "mCycDjiqDgGUmvRt630m1",
      "type": "text",
      "x": 36.020635930479045,
      "y": 3818.2742863822205,
      "width": 257.7622375488281,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
