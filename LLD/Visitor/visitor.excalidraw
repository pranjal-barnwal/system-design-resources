    {
      "id": "A2o99FN3n1I7pThhGyiP2",
      "type": "text",
      "x": 194.80078125,
      "y": 320.26953125,
      "width": 562.0196533203125,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 556884125,
      "version": 197,
      "versionNonce": 1260825474,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781949947993,
      "link": null,
      "locked": false,
      "text": "Suppose we want to add more functions() to a class, \nthen it basically breaks OCP (Open Closed Principle), SRP.\n\nAlso makes classes complex & difficult to test them",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Suppose we want to add more functions() to a class, \nthen it basically breaks OCP (Open Closed Principle), SRP.\n\nAlso makes classes complex & difficult to test them",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_zLRJ7SyZClvCvVJN5RnR",
