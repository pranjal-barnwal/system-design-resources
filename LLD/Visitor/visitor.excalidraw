    },
    {
      "id": "BUZLkS938_0WhQOFbJ8Q7",
      "type": "text",
      "x": 48.16515618041046,
      "y": 4831.109482224891,
      "width": 662.2924711416072,
      "height": 189,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b1x",
      "roundness": null,
      "seed": 1711191378,
      "version": 410,
      "versionNonce": 575254418,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781965996564,
      "link": null,
      "locked": false,
      "text": "What about both are changing?\n- what if number of methods is not constant and is updating\n- and along with it number of Concrete Classes on which those Methods\nare supposed to apply is also updating\n\nWill we use a combination of Visitor & Strategy or some different\napproach?",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What about both are changing?\n- what if number of methods is not constant and is updating\n- and along with it number of Concrete Classes on which those Methods are supposed to apply is also updating\n\nWill we use a combination of Visitor & Strategy or some different approach?",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "ZVrHuAnBI6AOabwKHZZi1",
      "type": "text",
      "x": 50.582706861908605,
      "y": 5023.876886387334,
      "width": 704.7502640265386,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b1z",
      "roundness": null,
      "seed": 2060677458,
      "version": 173,
      "versionNonce": 1615981906,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781965996564,
      "link": null,
      "locked": false,
      "text": "In this case, we actually prefere Strategy, even if OCP breaks, since\nit's simpler & more robust",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In this case, we actually prefere Strategy, even if OCP breaks, since it's simpler & more robust",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ETvq1458bYo3ImNIqEEg_",
      "type": "text",
      "x": 25.86787051316128,
      "y": 5227.641524446753,
      "width": 265.05181884765625,
      "height": 33.5,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
      "roundness": null,
      "seed": 1810337554,
      "version": 851,
      "versionNonce": 549168014,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781965848985,
      "link": null,
      "locked": false,
      "text": "Standard Definition:",
      "fontSize": 26.8,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Standard Definition:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IqtEDYcG5uSZ4d5C-TpbW",
      "type": "text",
      "x": 31.651782344961674,
      "y": 5272.313804648896,
      "width": 774.3189697265625,
      "height": 54,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
      "roundness": null,
      "seed": 567711758,
      "version": 183,
      "versionNonce": 1454811282,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781965974947,
      "link": null,
      "locked": false,
      "text": "Allows to add new Operations/Methods to existing classes w/o changing its structure.\nSeparates Operation from the Object it operates on.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Allows to add new Operations/Methods to existing classes w/o changing its structure.\nSeparates Operation from the Object it operates on.",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "_wf_GzehmvsNsD3JU8USm",
      "type": "text",
      "x": 36.44863799980567,
      "y": 5436.013400194952,
      "width": 659.3445293756866,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "b22",
      "roundness": null,
      "seed": 1670509006,
      "version": 383,
      "versionNonce": 1269021074,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781966177604,
      "link": null,
      "locked": false,
      "text": "Real life use-cases:\n1. Used heavily in Game-Engines as operations constantly increases\nas games become more complex.\n    ex: mapFetch(), render(), shaders(), reflectors(), noise()\n\n2. Also used in language-Compilers, where when AST is created,\nthen different functions are called for different token types",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Real life use-cases:\n1. Used heavily in Game-Engines as operations constantly increases as games become more complex.\n    ex: mapFetch(), render(), shaders(), reflectors(), noise()\n\n2. Also used in language-Compilers, where when AST is created, then different functions are called for different token types",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
