    {
      "id": "Xogl_D1UKfLSefD2Mz7L6",
      "type": "text",
      "x": 1221.8122182403367,
      "y": 1848.1013597872845,
      "width": 464.1498553356919,
      "height": 243,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#e7f5ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0Z",
      "roundness": null,
      "seed": 878867086,
      "version": 567,
      "versionNonce": 1656005138,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781960719724,
      "link": null,
      "locked": false,
      "text": "Depending on the type of Concrete Visitor passed;\nrequired function will be called.\n\nLike if Object v is of type ScanForVirusVisitor, then\ncurrent object this(Text/Video/Image) will be\nscanned for virus.\n\ntypeOf(this) --determines--> Document\ntypeOf(IVisitor v) --determines--> Function Visitor",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Depending on the type of Concrete Visitor passed; required function will be called.\n\nLike if Object v is of type ScanForVirusVisitor, then current object this(Text/Video/Image) will be scanned for virus.\n\ntypeOf(this) --determines--> Document\ntypeOf(IVisitor v) --determines--> Function Visitor",
      "autoResize": false,
      "lineHeight": 1.35
    },
