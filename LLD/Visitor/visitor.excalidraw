    {
      "id": "j6LaIzBv7rI-1SzxDG_N4",
      "type": "text",
      "x": 153.45782316887312,
      "y": 2192.080451357983,
      "width": 1034.7965000170768,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 50758030,
      "version": 565,
      "versionNonce": 44554190,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781955208811,
      "link": null,
      "locked": false,
      "text": "Like when we created ScanForVirusVisitor, the scanForVirus() function for each of TextFile, VideoFile &\nImageFile was created on the Concrete Visitor using Method-Overloading.\n\nSimilarly we can add any new functionality using Visitor & Method-Overloading.\n\nTraditional function extensions are instead being converted to Concrete-Visitor Classes and contains\nMethod-Overloaded Visit for each instance of Concrete-Classes on which that function is defined",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Like when we created ScanForVirusVisitor, the scanForVirus() function for each of TextFile, VideoFile & ImageFile was created on the Concrete Visitor using Method-Overloading.\n\nSimilarly we can add any new functionality using Visitor & Method-Overloading.\n\nTraditional function extensions are instead being converted to Concrete-Visitor Classes and contains Method-Overloaded Visit for each instance of Concrete-Classes on which that function is defined",
      "autoResize": false,
      "lineHeight": 1.25
    },
