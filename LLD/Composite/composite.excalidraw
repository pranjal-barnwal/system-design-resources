      "versionNonce": 411411789,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781260334476,
      "link": null,
      "locked": false,
      "text": "Here, we can't keep two different vectors of Files & Folders\nso instead we keep one vector, but then it will be of what?\nHence we create common parent abstract class for both Files & Folders",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here, we can't keep two different vectors of Files & Folders\nso instead we keep one vector, but then it will be of what?\nHence we create common parent abstract class for both Files & Folders",
      "autoResize": true,
      "lineHeight": 1.25
    },
