      "boundElements": [],
      "updated": 1777204256324,
      "link": null,
      "locked": false,
      "text": "In application our user or object goes throgh diffrent phases or states, like in vending machine it goes thorgh \nlike vendin Machine HasCoinState, NoCoinState, DespenseItem, SoldOutState etc",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In application our user or object goes throgh diffrent phases or states, like in vending machine it goes thorgh \nlike vendin Machine HasCoinState, NoCoinState, DespenseItem, SoldOutState etc",
      "autoResize": true,
